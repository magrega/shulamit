{
  "name": "shulamit-vite",
  "private": true,
  "homepage": "https://magrega.github.io/shulamit",
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "dev:client": "vite --host",
    "dev:api": "json-server public/cards.json --port 3002",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:api\"",
    "build": "tsc -b && vite build",
    "build:win": "tsc -b && vite build && copy nginx.conf dist/nginx.conf",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "ftp": "tsc -b && vite build && copy nginx.conf dist/nginx.conf && node --env-file=.env ftpDeploy.js",
    "serve": "concurrently --kill-others \"serve -s dist -l 5173\" \"json-server public/cards.json --port 3002\""
  },
  "dependencies": {
    "axios": "^1.8.3",
    "concurrently": "^9.2.1",
    "json-server": "^1.0.0-beta.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.2.0",
    "react-spinners": "^0.15.0",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "ftp-deploy": "^2.4.7",
    "globals": "^15.15.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0"
  }
}
